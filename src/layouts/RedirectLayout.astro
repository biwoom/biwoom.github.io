---
import { url } from '../lib/url';

interface Props {
  to: string;
}

const { to } = Astro.props;
const target = url(to);
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="robots" content="noindex" />
  <meta http-equiv="refresh" content={`0;url=${target}`} />
  <link rel="canonical" href={target} />
  <title>Redirecting...</title>
</head>
<body>
  <a href={target}>Redirecting...</a>
</body>
</html>
