---
import { getDesignAssetKeyUrl } from '../../lib/assets';
import { url } from '../../lib/url';

interface Props {
  entity: {
    id: string;
    type: string;
    name: { ko: string; en?: string; pali?: string; sanskrit?: string; chinese?: string };
    aliases?: string[];
    description?: string;
    tags?: string[];
    design?: {
      imageAsset?: string;
      profileImage?: string;
    };
  };
}

const { entity } = Astro.props;
const names = [entity.name.en, entity.name.sanskrit, entity.name.pali, entity.name.chinese].filter(Boolean);
const profileImage = entity.design?.imageAsset
  ? getDesignAssetKeyUrl(entity.design.imageAsset)
  : entity.design?.profileImage
    ? url(entity.design.profileImage)
    : '';
---

<aside class="ol-card ol-entity-panel">
  {profileImage && (
    <figure class="ol-entity-panel-profile">
      <img src={profileImage} alt={`${entity.name.ko} 프로필 이미지`} loading="lazy" decoding="async" />
    </figure>
  )}
  <div class="ol-meta-label">{entity.type.toUpperCase()}</div>
  <h2 class="ol-entity-panel-title ol-kr">{entity.name.ko}</h2>

  {names.length > 0 && (
    <p class="ol-entity-panel-names">
      {names.join(' · ')}
    </p>
  )}

  {entity.aliases && entity.aliases.length > 0 && (
    <div class="ol-entity-panel-block ol-entity-panel-block--aliases">
      <div class="ol-meta-label ol-entity-panel-label">별칭</div>
      <p class="ol-entity-panel-aliases">{entity.aliases.join(', ')}</p>
    </div>
  )}

  {entity.description && (
    <div class="ol-entity-panel-block">
      <p class="ol-entity-panel-description ol-kr">{entity.description}</p>
    </div>
  )}

  {entity.tags && entity.tags.length > 0 && (
    <div class="ol-entity-panel-block">
      <div class="ol-meta-label ol-entity-panel-label--tags">태그</div>
      <div class="ol-entity-panel-tags">
        {entity.tags.map(tag => (
          <span class="ol-meta-badge">{tag}</span>
        ))}
      </div>
    </div>
  )}
</aside>
