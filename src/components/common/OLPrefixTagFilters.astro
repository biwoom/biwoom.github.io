---
import type { PrefixTagGroup } from '../../lib/tags';

interface Props {
  id: string;
  groups: PrefixTagGroup[];
  targetSelector: string;
  totalCount: number;
  emptySelector?: string;
  pageSize?: number;
  loadMoreWrapSelector?: string;
  loadMoreButtonSelector?: string;
  loadMoreRemainingSelector?: string;
}

const {
  id,
  groups,
  targetSelector,
  totalCount,
  emptySelector,
  pageSize,
  loadMoreWrapSelector,
  loadMoreButtonSelector,
  loadMoreRemainingSelector,
} = Astro.props;
---

{groups.length > 0 && (
  <section
    class="ol-prefix-filter"
    id={id}
    data-prefix-filter
    data-target-selector={targetSelector}
    data-empty-selector={emptySelector}
    data-page-size={pageSize}
    data-loadmore-wrap-selector={loadMoreWrapSelector}
    data-loadmore-button-selector={loadMoreButtonSelector}
    data-loadmore-remaining-selector={loadMoreRemainingSelector}
    aria-label="태그 필터"
  >
    <div class="ol-prefix-filter-controls">
      <button class="ol-prefix-filter-reset active" type="button" data-filter-reset>
        전체 <span>{totalCount}</span>
      </button>

      {groups.map(group => (
        <details class="ol-prefix-filter-menu" data-prefix={group.prefix}>
          <summary>
            <span data-prefix-label>{group.prefix}</span>
            <span class="ol-prefix-filter-count">{group.tags.length}</span>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9" />
            </svg>
          </summary>
          <div class="ol-prefix-filter-panel">
            {group.tags.map(item => (
              <button type="button" data-filter-tag={item.tag} data-filter-prefix={group.prefix} data-filter-label={item.label}>
                <span>{item.label}</span>
                <span>{item.count}</span>
              </button>
            ))}
          </div>
        </details>
      ))}
    </div>

    <div class="ol-prefix-filter-active" data-filter-active hidden></div>
  </section>
)}

<script>
  import { initPrefixFilters } from '../../lib/client/content-filters';

  initPrefixFilters();
</script>
