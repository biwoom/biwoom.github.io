---
import { url } from '../../lib/url';

const navItems = [
  { href: url('/'),       label: 'HOME' },
  { href: url('/text'),  label: 'TEXT' },
  { href: url('/story'),   label: 'STORY' },
  { href: url('/design'), label: 'DESIGN' },
  { href: url('/net'), label: 'NET' },
  // { href: url('/atlas'),  label: 'ATLAS' },
  // { href: url('/ai'),     label: 'AI' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  if (href === url('/')) return currentPath === href || currentPath === base || currentPath === base + '/';
  return currentPath.startsWith(href);
}
---

<header class="ol-header" data-pagefind-ignore>
  <div class="ol-container ol-header-inner">
    <!-- Brand -->
    <a href={url('/')} class="ol-brand">
      <span class="ol-brand-name">OL</span>
      <span class="ol-brand-meta">Weaving the Wisdom</span>
    </a>

    <!-- Nav -->
    <nav class="ol-nav" aria-label="주요 메뉴">
      {navItems.map(item => (
        <a
          href={item.href}
          class:list={['ol-nav-link', { 'active': isActive(item.href) }]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Right actions -->
    <div class="ol-header-right">

      <!-- 검색 트리거 -->
      <button
        id="ol-search-trigger"
        class="ol-btn ol-btn-ghost ol-btn-sm ol-btn-icon"
        title="검색 (⌘K)"
        aria-label="검색"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>

      <!-- Dark mode toggle -->
      <button
        id="ol-theme-toggle"
        class="ol-btn ol-btn-ghost ol-btn-sm ol-btn-icon"
        title="테마 전환"
        aria-label="다크모드 전환"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg class="ol-icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg class="ol-icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- 모바일 햄버거 버튼 (데스크탑에서 숨김) -->
      <button
        class="ol-mobile-menu-trigger"
        id="ol-mobile-menu-trigger"
        aria-label="메뉴 열기"
        aria-expanded="false"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="4" y1="6" x2="20" y2="6"/>
          <line x1="4" y1="12" x2="20" y2="12"/>
          <line x1="4" y1="18" x2="20" y2="18"/>
        </svg>
      </button>
            
      <!-- Blog link -->
      <a href={url('/blog')} class="ol-btn ol-btn-outline ol-btn-sm">BLOG</a>

      <!-- GitHub -->
      <a
        href="https://github.com/biwoom"
        class="ol-btn ol-btn-primary ol-btn-sm"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2.21c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.47.11-3.06 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.9-.39.99 0 1.98.13 2.9.39 2.21-1.5 3.18-1.18 3.18-1.18.63 1.59.23 2.77.11 3.06.74.81 1.19 1.84 1.19 3.1 0 4.43-2.69 5.4-5.26 5.68.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.79.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/>
        </svg>
        GitHub
      </a>
    </div>
  </div>
</header>

<!-- 모바일 하단 시트 메뉴 -->
<div class="ol-mobile-overlay" id="ol-mobile-overlay" aria-hidden="true">
  <nav class="ol-mobile-sheet" id="ol-mobile-sheet" role="navigation" aria-label="모바일 메뉴">

    <div class="ol-mobile-sheet-handle"></div>

    <div class="ol-mobile-sheet-links">
      {navItems.map(item => (
        <a
          href={item.href}
          class:list={['ol-mobile-sheet-link', { active: isActive(item.href) }]}
        >
          {item.label}
        </a>
      ))}

      <div class="ol-mobile-sheet-divider"></div>

      <a href={url('/blog')} class="ol-mobile-sheet-link ol-mobile-sheet-link--sub">BLOG</a>
      <a
        href="https://github.com/biwoom"
        class="ol-mobile-sheet-link ol-mobile-sheet-link--sub"
        target="_blank"
        rel="noopener noreferrer"
      >
        GitHub
        <svg class="ol-mobile-sheet-link-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M7 17 17 7"/><path d="M7 7h10v10"/>
        </svg>
      </a>
    </div>

    <button class="ol-mobile-sheet-close" id="ol-mobile-sheet-close" aria-label="메뉴 닫기">
      닫기
    </button>

  </nav>
</div>

<script>
  // 모바일 메뉴 하단 시트
  const mobileMenuTrigger = document.getElementById('ol-mobile-menu-trigger');
  const mobileOverlay = document.getElementById('ol-mobile-overlay');
  const mobileSheet = document.getElementById('ol-mobile-sheet');
  const mobileCloseBtn = document.getElementById('ol-mobile-sheet-close');

  function openMobileMenu() {
    mobileOverlay?.setAttribute('aria-hidden', 'false');
    mobileMenuTrigger?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMobileMenu() {
    mobileOverlay?.setAttribute('aria-hidden', 'true');
    mobileMenuTrigger?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  mobileMenuTrigger?.addEventListener('click', openMobileMenu);
  mobileCloseBtn?.addEventListener('click', closeMobileMenu);

  mobileOverlay?.addEventListener('click', (e) => {
    if (e.target === mobileOverlay) closeMobileMenu();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileOverlay?.getAttribute('aria-hidden') === 'false') {
      closeMobileMenu();
    }
  });

  mobileSheet?.querySelectorAll('.ol-mobile-sheet-link').forEach(link => {
    link.addEventListener('click', () => closeMobileMenu());
  });
</script>

<script>
  const btn = document.getElementById('ol-theme-toggle');
  btn?.addEventListener('click', () => {
    const root = document.documentElement;
    root.classList.add('theme-switching');
    const isDark = root.classList.toggle('dark');
    localStorage.setItem('ol-theme', isDark ? 'dark' : 'light');
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        root.classList.remove('theme-switching');
      });
    });
  });
</script>
