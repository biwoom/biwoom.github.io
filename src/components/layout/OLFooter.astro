---
import { url } from '../../lib/url';
import { site } from '../../lib/site';
const currentYear = new Date().getFullYear();
---

<footer class="ol-footer" data-pagefind-ignore>
  <div class="ol-container">
    <div class="ol-footer-grid">
      <!-- Brand column -->
      <div>
        <div class="ol-brand" style="margin-bottom: 10px;">
          <span class="ol-brand-name">{site.name}</span>
          <span style="color: var(--ol-muted); font-size: 14px; font-weight: 500;">{site.tagline}</span>
        </div>
        <p style="color: var(--ol-muted); font-size: 13px; line-height: 1.6; max-width: 32ch;" class="ol-kr">
          손에서 손으로 이어지는 열린 불교 콘텐츠
        </p>
        <div style="margin-top: 14px; display: flex; gap: 8px;">
          <a href={site.github} class="ol-btn ol-btn-sm ol-btn-icon" aria-label="GitHub" target="_blank" rel="noopener">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2.21c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.47.11-3.06 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.9-.39.99 0 1.98.13 2.9.39 2.21-1.5 3.18-1.18 3.18-1.18.63 1.59.23 2.77.11 3.06.74.81 1.19 1.84 1.19 3.1 0 4.43-2.69 5.4-5.26 5.68.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.79.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/>
            </svg>
          </a>
          <a href={`mailto:${site.email}`} class="ol-btn ol-btn-sm ol-btn-icon" aria-label="이메일">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Projects -->
      <div>
        <h4>PROJECTS</h4>
        <!-- <a href={url('/atlas')}>OL ATLAS</a> -->
        <a href={url('/text')}>OL TEXT</a>  
        <a href={url('/story')}>OL STORY</a>
        <a href={url('/design')}>OL DESIGN</a>
        <!-- <a href={url('/ai')}>OL AI</a> -->
      </div>

      <!-- Read -->
      <div>
        <h4>READ</h4>
        <a href={url('/blog')}>BLOG · 작업 일지</a>
        <a href={url('/pages/brand')}>OL 브랜드 정의서</a>
        <a href={url('/partners')}>기여 및 협력단체</a>
      </div>

      <!-- Open -->
      <div>
        <h4>OPEN</h4>
        <a href={site.github} target="_blank" rel="noopener">GitHub 저장소</a>
        <a href={site.license} target="_blank" rel="noopener">CC0 · 라이선스</a>
        <a href={`mailto:${site.email}`}>문의 및 기여</a>
      </div>
    </div>

    <div class="ol-footer-bottom">
      <span>© {currentYear} OL · 오픈 소스 불교콘텐츠</span>
      <span>Weaving the Wisdom</span>
    </div>
  </div>
</footer>
