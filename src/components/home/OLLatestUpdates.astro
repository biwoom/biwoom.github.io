---
import { getCollection } from 'astro:content';
import { url } from '../../lib/url';

const recentPosts = (
  await getCollection('blog', e => e.data.published)
)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

function formatDate(date: Date): string {
  return date.toLocaleDateString('ko-KR', {
    year: 'numeric', month: '2-digit', day: '2-digit',
  }).replace(/\. /g, '.').replace(/\.$/, '');
}
---
<section class="ol-section">
  <div class="ol-container">
    <div class="ol-row ol-latest-head">
      <div>
            <span class="ol-section-label">LATEST · 최근 소식</span>
        <h2 class="ol-latest-title ol-kr">최근 업데이트</h2>
      </div>
      <div class="ol-spacer"></div>
      <a href={url('/blog')} class="ol-btn ol-btn-ghost ol-btn-sm">전체 보기 →</a>
    </div>

    {recentPosts.length > 0 ? (
      <div class="ol-grid-3">
        {recentPosts.map(post => (
          <a
            href={url(`/blog/${post.id}`)}
            class="ol-card ol-card-tight ol-latest-card"
          >
            <span class="ol-meta-label">
              {formatDate(post.data.date)}{post.data.category ? ` · ${post.data.category}` : ''}
            </span>
            <h4 class="ol-latest-card-title ol-kr">
              {post.data.title}
            </h4>
            {post.data.description && (
              <p class="ol-latest-card-copy ol-kr">
                {post.data.description}
              </p>
            )}
          </a>
        ))}
      </div>
    ) : (
      <div class="ol-grid-3">
        <article class="ol-card ol-card-tight">
          <span class="ol-meta-label">2026.05.21 · ATLAS</span>
          <h4 class="ol-latest-card-title ol-latest-card-title--fallback ol-kr">v0.4.2 — 단일 파일 내보내기 개선</h4>
          <p class="ol-latest-card-copy ol-latest-card-copy--fallback ol-kr">에디터에서 작성한 콘텐츠를 5MB 이하 단일 HTML 파일로 압축하는 흐름을 정비했습니다.</p>
        </article>
        <article class="ol-card ol-card-tight">
          <span class="ol-meta-label">2026.05.14 · STORY</span>
          <h4 class="ol-latest-card-title ol-latest-card-title--fallback ol-kr">담마빠다 7장 공개</h4>
          <p class="ol-latest-card-copy ol-latest-card-copy--fallback ol-kr">아라한품 26게송과 주석 5편. 빨리어 원문 대조 포함, ATLAS 뷰어로 바로 열립니다.</p>
        </article>
        <article class="ol-card ol-card-tight">
          <span class="ol-meta-label">2026.05.07 · DESIGN</span>
          <h4 class="ol-latest-card-title ol-latest-card-title--fallback ol-kr">고려 후기 승복 레퍼런스 38점</h4>
          <p class="ol-latest-card-copy ol-latest-card-copy--fallback ol-kr">박물관 자료와 회화에서 추출한 색상·재질 팔레트와 도식. 모두 CC0로 배포됩니다.</p>
        </article>
      </div>
    )}
  </div>
</section>
