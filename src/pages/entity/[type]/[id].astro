---
import { getCollection, render } from 'astro:content';
import EntityLayout from '../../../layouts/EntityLayout.astro';
import OLEntityPanel from '../../../components/entity/OLEntityPanel.astro';
import OLRelationLinks from '../../../components/entity/OLRelationLinks.astro';
import { getEntityRelations, getBacklinks } from '../../../lib/relations';
import { url } from '../../../lib/url';

export async function getStaticPaths() {
  const entities = await getCollection('entities', e => e.data.published);
  return entities.map(entry => ({
    params: {
      type: entry.data.type + 's',
      id: entry.data.id,
    },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const entities = await getCollection('entities', e => e.data.published);
const allRelations = entities.flatMap(e => e.data.relations ?? []);
const entityMap = new Map(entities.map(entity => [entity.data.id, entity]));

const outgoing = getEntityRelations(entry.data.id, allRelations);
const backlinks = getBacklinks(entry.data.id, allRelations);
const entityTypeLabel: Record<string, string> = {
  person: '인물',
  concept: '개념',
  place: '장소',
  text: '문헌',
  practice: '수행',
  event: '사건',
  school: '학파',
};
const pagefindType = entityTypeLabel[entry.data.type] ?? entry.data.type;
const pagefindBreadcrumb = ['ENTITY', pagefindType]
  .filter(Boolean)
  .join(' · ');
---

<EntityLayout
  title={`${entry.data.name.ko} — OL ENTITY`}
  pagefindMeta={{
    title: entry.data.name.ko,
    section: 'ENTITY',
    sectionLabel: 'ENTITY',
    type: pagefindType,
    breadcrumb: pagefindBreadcrumb,
  }}
>
  <div class="ol-text-breadcrumb ol-entity-breadcrumb">
    <a href={url('/entity')}>ENTITY</a>
    <span>/</span>
    <span>{pagefindType}</span>
  </div>
  <div class="ol-entity-detail-shell">
    <article class="ol-entity-detail-main">
      <header class="ol-entity-detail-header">
        <span class="ol-meta-label">{entry.data.type.toUpperCase()}</span>
        <h1 class="ol-kr">
          {entry.data.name.ko}
        </h1>
        {entry.data.name.en && (
          <div class="ol-entity-detail-meta">
            {entry.data.name.en}
            {entry.data.name.sanskrit && ` · Skt. ${entry.data.name.sanskrit}`}
            {entry.data.name.pali && ` · Pāli ${entry.data.name.pali}`}
          </div>
        )}
      </header>

      <div class="ol-prose">
        <Content />
      </div>

      {outgoing.length > 0 && (
        <OLRelationLinks title="관계" relations={outgoing} direction="outgoing" entityMap={entityMap} />
      )}
      {backlinks.length > 0 && (
        <OLRelationLinks title="역참조" relations={backlinks} direction="incoming" entityMap={entityMap} />
      )}
    </article>

    <aside class="ol-entity-detail-side">
      <OLEntityPanel entity={entry.data} />
    </aside>
  </div>
</EntityLayout>
