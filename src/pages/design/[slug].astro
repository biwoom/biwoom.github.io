---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getGeneratedAssetUrl, getVersionedDownloadFilename } from '../../lib/assets';
import { url } from '../../lib/url';
import {
  formatLabel,
  getDesignPreviewAssets,
  primaryKindLabel,
  typeLabel,
} from '../../lib/design';
import { getStoryEntryUrl, isStoryDocumentEntry, sortStoryEntries } from '../../lib/story';
import { getTextEntryUrl, isTextDocumentEntry, sortTextEntries } from '../../lib/text';

export async function getStaticPaths() {
  const items = await getCollection('design', e => e.data.published);
  return items.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const previewAssets = getDesignPreviewAssets(entry.data);
const previewAsset = previewAssets[0];
const description = entry.data.description ?? entry.data.summary ?? entry.data.imageAlt ?? entry.data.title;
const allTags = entry.data.tags;
const showImageDownload = entry.data.format === 'image' && Boolean(entry.data.imageAsset);
const pagefindKind = primaryKindLabel[entry.data.primaryKind] ?? entry.data.primaryKind;
const pagefindType = entry.data.type ? (typeLabel[entry.data.type] ?? entry.data.type) : undefined;
const pagefindBreadcrumb = ['DESIGN', pagefindKind, pagefindType, entry.data.series]
  .filter(Boolean)
  .join(' · ');
const allEntities = await getCollection('entities', e => e.data.published);
const entityById = new Map(allEntities.map(entity => [entity.data.id, entity]));
const designEntityIds = new Set(entry.data.entities);
const designEntities = Array.from(designEntityIds)
  .map(id => entityById.get(id))
  .filter((entity): entity is typeof allEntities[number] => Boolean(entity));
const textEntries = sortTextEntries(
  await getCollection('text', e => e.data.published !== false && isTextDocumentEntry(e)),
);
const storyEntries = sortStoryEntries(
  await getCollection('story', e => e.data.published && isStoryDocumentEntry(e)),
);

type RelatedReference = {
  type?: string;
  title: string;
  path: string;
  role?: string;
};

function designAsset(asset?: string) {
  return getGeneratedAssetUrl('design', entry.id, asset);
}

function getDownloadFilename(asset?: string) {
  return getVersionedDownloadFilename(entry.data.title, entry.data.version, asset);
}

function normalizeReferenceKey(value: string) {
  return value
    .trim()
    .replace(/^https?:\/\/biwoom\.github\.io/i, '')
    .replace(/^\/+|\/+$/g, '');
}

function uniqueReferences(refs: RelatedReference[]) {
  const seen = new Set<string>();
  return refs.filter(ref => {
    const key = `${normalizeReferenceKey(ref.path)}|${ref.title}`;
    if (seen.has(key)) return false;
    seen.add(key);
    return true;
  });
}

const textReferenceCandidates = new Map<string, typeof textEntries[number]>();
textEntries.forEach(text => {
  const path = getTextEntryUrl(text);
  [
    text.id,
    path,
    path.replace(/^\/text\//, ''),
  ].forEach(key => textReferenceCandidates.set(normalizeReferenceKey(key), text));
});

const storyReferenceCandidates = new Map<string, typeof storyEntries[number]>();
storyEntries.forEach(story => {
  const path = getStoryEntryUrl(story);
  [
    story.id,
    path,
    path.replace(/^\/story\//, ''),
  ].forEach(key => storyReferenceCandidates.set(normalizeReferenceKey(key), story));
});

const relatedWorksText = entry.data.relatedWorks
  .map(work => textReferenceCandidates.get(normalizeReferenceKey(work)))
  .filter((text): text is typeof textEntries[number] => Boolean(text))
  .map(text => ({
    title: text.data.title,
    path: url(getTextEntryUrl(text)),
  }));

const relatedWorksStory = entry.data.relatedWorks
  .map(work => storyReferenceCandidates.get(normalizeReferenceKey(work)))
  .filter((story): story is typeof storyEntries[number] => Boolean(story))
  .map(story => ({
    title: story.data.title,
    path: url(getStoryEntryUrl(story)),
  }));

const relatedTextLinks = uniqueReferences(relatedWorksText);
const relatedStoryLinks = uniqueReferences(relatedWorksStory);
const hasRelatedContext = designEntities.length > 0 || relatedTextLinks.length > 0 || relatedStoryLinks.length > 0;
const typeLabels: Record<string, string> = {
  person: '인물',
  place: '장소',
  concept: '개념',
  text: '문헌',
  event: '사건',
  practice: '수행',
  school: '학파',
};
---

<BaseLayout
  title={`${entry.data.title} — OL DESIGN`}
  description={description}
  pagefindMeta={{
    title: entry.data.title,
    section: 'DESIGN',
    sectionLabel: 'DESIGN',
    category: pagefindKind,
    type: pagefindType,
    series: entry.data.series,
    breadcrumb: pagefindBreadcrumb,
  }}
>
  <main>
    <div class="ol-design-detail-wrap">
      <div class="ol-container">

        <nav class="ol-design-detail-nav">
          <a href={url('/design')} class="ol-design-back-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
            DESIGN 라이브러리
          </a>
        </nav>

        <div class="ol-design-detail">

          <div class="ol-design-detail-img-col">
            {previewAsset ? (
              <div class="ol-design-preview-stack">
                {previewAssets.map((asset, index) => (
                  <figure class="ol-design-detail-img-frame">
                    <img
                      src={designAsset(asset)}
                      alt={`${entry.data.imageAlt ?? entry.data.title}${previewAssets.length > 1 ? ` ${index + 1}` : ''}`}
                      loading={index === 0 ? 'eager' : 'lazy'}
                      decoding="async"
                    />
                    {previewAssets.length > 1 && (
                      <figcaption>PREVIEW {index + 1}</figcaption>
                    )}
                  </figure>
                ))}
              </div>
            ) : (
              <div class="ol-ph ol-design-detail-img-frame ol-design-detail-img-frame--placeholder">
                {primaryKindLabel[entry.data.primaryKind] ?? 'DESIGN'}
              </div>
            )}
          </div>

          <div class="ol-design-detail-meta-col">

            <header class="ol-design-detail-header">
              <div class="ol-design-detail-type-badge">
                {primaryKindLabel[entry.data.primaryKind]}
                {entry.data.type && ` · ${typeLabel[entry.data.type] ?? entry.data.type}`}
              </div>
              <h1 class="ol-design-detail-title ol-kr">{entry.data.title}</h1>
              {description && (
                <p class="ol-design-detail-summary ol-kr">{description}</p>
              )}
            </header>

            {(entry.data.htmlAsset || entry.data.pdfAsset || showImageDownload) && (
              <div class="ol-design-detail-actions">
                {entry.data.htmlAsset && (
                  <a
                    href={designAsset(entry.data.htmlAsset)}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="ol-btn ol-btn-primary"
                  >
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                      <polyline points="15 3 21 3 21 9"/>
                      <line x1="10" y1="14" x2="21" y2="3"/>
                    </svg>
                    웹브라우저로 보기
                  </a>
                )}
                {entry.data.pdfAsset && (
                  <a
                    href={designAsset(entry.data.pdfAsset)}
                    download={getDownloadFilename(entry.data.pdfAsset)}
                    class="ol-btn ol-btn-outline"
                  >
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M12 3v13m0 0 4-4m-4 4-4-4M4 21h16"/>
                    </svg>
                    PDF 다운로드
                  </a>
                )}
                {showImageDownload && entry.data.imageAsset && (
                  <a
                    href={designAsset(entry.data.imageAsset)}
                    download={getDownloadFilename(entry.data.imageAsset)}
                    class="ol-btn ol-btn-outline"
                  >
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M12 3v13m0 0 4-4m-4 4-4-4M4 21h16"/>
                    </svg>
                    이미지 다운로드
                  </a>
                )}
              </div>
            )}

            <dl class="ol-design-detail-dl">
              <dt>형식</dt>
              <dd>{formatLabel[entry.data.format] ?? entry.data.format}</dd>

              <dt>버전</dt>
              <dd><span class="ol-meta-badge">v{entry.data.version}</span></dd>

              <dt>상태</dt>
              <dd>{entry.data.status}</dd>

              {entry.data.series && (
                <>
                  <dt>시리즈</dt>
                  <dd class="ol-kr">{entry.data.series}</dd>
                </>
              )}
              {entry.data.scriptureRef && (
                <>
                  <dt>출전</dt>
                  <dd class="ol-kr">{entry.data.scriptureRef}</dd>
                </>
              )}
              {entry.data.era && (
                <>
                  <dt>시대</dt>
                  <dd class="ol-kr">{entry.data.era}</dd>
                </>
              )}
              {entry.data.region && (
                <>
                  <dt>지역</dt>
                  <dd class="ol-kr">{entry.data.region}</dd>
                </>
              )}
              {entry.data.tradition && (
                <>
                  <dt>전통</dt>
                  <dd class="ol-kr">{entry.data.tradition}</dd>
                </>
              )}
              {entry.data.medium && (
                <>
                  <dt>매체</dt>
                  <dd>{entry.data.medium}</dd>
                </>
              )}
              {entry.data.dimensions && (
                <>
                  <dt>크기</dt>
                  <dd>{entry.data.dimensions}</dd>
                </>
              )}
              {entry.data.pageSize && (
                <>
                  <dt>지면</dt>
                  <dd>{entry.data.pageSize}</dd>
                </>
              )}
              {entry.data.orientation && (
                <>
                  <dt>방향</dt>
                  <dd>{entry.data.orientation}</dd>
                </>
              )}
              {entry.data.source && (
                <>
                  <dt>출처</dt>
                  <dd>
                    {entry.data.sourceUrl ? (
                      <a href={entry.data.sourceUrl} target="_blank" rel="noopener noreferrer">
                        {entry.data.source}
                      </a>
                    ) : entry.data.source}
                  </dd>
                </>
              )}
              <dt>라이선스</dt>
              <dd><span class="ol-meta-badge">{entry.data.license}</span></dd>
            </dl>

            {allTags.length > 0 && (
              <div class="ol-design-detail-tags">
                {allTags.map(tag => (
                  <a
                    href={url(`/design?tag=${encodeURIComponent(tag)}`)}
                    class="ol-design-tag-link"
                  >
                    #{tag}
                  </a>
                ))}
              </div>
            )}

            {hasRelatedContext && (
              <aside class="ol-design-related-panel" aria-label="관련 이름카드와 문서" data-pagefind-ignore>
                <div class="ol-design-related-stats">
                  <span>
                    <strong>{designEntities.length}</strong>
                    <em>이름카드</em>
                  </span>
                  <span>
                    <strong>{relatedStoryLinks.length + relatedTextLinks.length}</strong>
                    <em>관련 문서</em>
                  </span>
                </div>

                {designEntities.length > 0 && (
                  <section class="ol-design-related-section ol-design-related-section--cards">
                    <h2>관련 이름카드</h2>
                    <ul>
                      {designEntities.map(entity => (
                        <li>
                          <a href={url(`/entity/${entity.data.type}s/${entity.data.id}`)}>
                            <span class="ol-meta-label">{typeLabels[entity.data.type] ?? entity.data.type}</span>
                            <strong class="ol-kr">{entity.data.name.ko}</strong>
                            {entity.data.description && <em class="ol-kr">{entity.data.description}</em>}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </section>
                )}

                {relatedStoryLinks.length > 0 && (
                  <section class="ol-design-related-section">
                    <h2>관련 STORY</h2>
                    <ul>
                      {relatedStoryLinks.map(ref => (
                        <li>
                          <a href={ref.path}>
                            <span>{ref.title}</span>
                            {ref.role && <em>{ref.role}</em>}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </section>
                )}

                {relatedTextLinks.length > 0 && (
                  <section class="ol-design-related-section">
                    <h2>관련 TEXT</h2>
                    <ul>
                      {relatedTextLinks.map(ref => (
                        <li>
                          <a href={ref.path}>
                            <span>{ref.title}</span>
                            {ref.role && <em>{ref.role}</em>}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </section>
                )}
              </aside>
            )}

            <div class="ol-divider"></div>

            <div class="ol-prose ol-kr ol-design-detail-prose">
              <Content />
            </div>

          </div>
        </div>

      </div>
    </div>
  </main>
</BaseLayout>
