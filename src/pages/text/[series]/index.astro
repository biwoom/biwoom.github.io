---
import { getCollection } from 'astro:content';
import OLTagResultsModal from '../../../components/common/OLTagResultsModal.astro';
import TextLayout from '../../../layouts/TextLayout.astro';
import { url } from '../../../lib/url';
import { buildTextHierarchy, getTextEntryUrl, formatTextTag } from '../../../lib/text';
import { getPublicTags } from '../../../lib/tags';

export async function getStaticPaths() {
  const texts = await getCollection('text', e => e.data.published !== false);
  return buildTextHierarchy(texts).map(series => ({
    params: { series: series.slug },
    props: { series },
  }));
}

const { series } = Astro.props;
const seriesTags = [...new Set([
  ...getPublicTags(series.meta?.data.tags ?? []),
  ...series.entries.flatMap(entry => getPublicTags(entry.data.tags)),
])].sort((a, b) => a.localeCompare(b, 'ko'));
const seriesDescription = series.meta?.data.description ?? series.meta?.data.excerpt;
const tagIndex = new Map<string, Array<{
  partLabel: string;
  partOrder: number;
  groupLabel: string;
  groupOrder: number;
  entryId: string;
  title: string;
  chapter: number | undefined;
  href: string;
}>>();

for (const part of series.parts) {
  for (const group of part.groups) {
    for (const entry of group.entries) {
      for (const tag of getPublicTags(entry.data.tags)) {
        const items = tagIndex.get(tag) ?? [];
        items.push({
          partLabel: part.label,
          partOrder: part.order,
          groupLabel: group.label,
          groupOrder: group.order,
          entryId: entry.id,
          title: entry.data.title,
          chapter: entry.data.chapter,
          href: url(getTextEntryUrl(entry)),
        });
        tagIndex.set(tag, items);
      }
    }
  }
}

const tagGroups = Array.from(tagIndex.entries())
  .map(([tag, items]) => {
    const parsed = formatTextTag(tag);
    return { tag, ...parsed, items };
  })
  .sort((a, b) => a.prefix.localeCompare(b.prefix, 'ko') || a.label.localeCompare(b.label, 'ko'))
  .reduce<Array<{
    prefix: string;
    tags: Array<{ tag: string; label: string; items: Array<{
      partLabel: string;
      partOrder: number;
      groupLabel: string;
      groupOrder: number;
      entryId: string;
      title: string;
      chapter: number | undefined;
      href: string;
    }> }>;
  }>>((groups, tag) => {
    const group = groups.find(item => item.prefix === tag.prefix);
    const tagItem = { tag: tag.tag, label: tag.label, items: tag.items };
    if (group) group.tags.push(tagItem);
    else groups.push({ prefix: tag.prefix, tags: [tagItem] });
    return groups;
  }, []);

---

<TextLayout
  title={`${series.label} — OL TEXT`}
  description={seriesDescription ?? `${series.label} 시리즈 문헌 콘텐츠`}
  seriesSlug={series.slug}
>
  <article class="ol-text-article ol-text-series-page" data-tag-results-index>
    <header class="ol-text-doc-header">
      <div class="ol-text-breadcrumb">
        <a href={url('/text')}>TEXT</a>
        <span>/</span>
        <span>{series.label}</span>
      </div>
      <h1 class="ol-kr">{series.label}</h1>
      <p class="ol-kr">
        {seriesDescription ?? `이 시리즈는 ${series.count}개의 문서를 part, chapter 구조로 정리합니다.`}
      </p>

      {tagGroups.length > 0 && (
        <div class="ol-text-tag-index" data-text-tag-index>
          {tagGroups.map(group => (
            <div class="ol-text-tag-menu">
              <button class="ol-text-tag-menu-trigger" type="button" aria-expanded="false" data-text-tag-menu-trigger data-tag-menu-trigger>
                <span>{group.prefix}</span>
                <strong>{group.tags.length}</strong>
              </button>
              <div class="ol-text-tag-menu-panel">
                {group.tags.map(tag => (
                  <button
                    type="button"
                    data-text-tag-select={tag.tag}
                    data-text-tag-label={tag.label}
                    data-tag-select
                    data-tag-value={tag.tag}
                    data-tag-label={tag.label}
                  >
                    <span>{tag.label}</span>
                    <strong>{tag.items.length}</strong>
                  </button>
                ))}
              </div>
            </div>
          ))}
        </div>
      )}
    </header>

    {series.entries.length > 0 && tagGroups.length > 0 && (
      <OLTagResultsModal
        variant="text"
        emptyText="선택한 태그 조합에 해당하는 문서가 없습니다."
      >
        {series.parts.map((part, partIndex) => (
          <section class="ol-tag-results-section" data-text-result-part data-tag-result-part>
            <h3>PART {partIndex + 1} · {part.label}</h3>
            {part.groups.map(group => (
              <div class="ol-tag-results-group" data-text-result-group data-tag-result-group>
                <p>{group.label}</p>
                <ol>
                  {group.entries.map((entry, entryIndex) => (
                    <li data-text-result-entry data-tag-result-entry data-tags={JSON.stringify(getPublicTags(entry.data.tags))}>
                      <a href={url(getTextEntryUrl(entry))}>
                        <span>{String(entry.data.chapter ?? entryIndex + 1).padStart(2, '0')}</span>
                        <strong class="ol-kr">{entry.data.title}</strong>
                      </a>
                    </li>
                  ))}
                </ol>
              </div>
            ))}
          </section>
        ))}
      </OLTagResultsModal>
    )}

    <div class="ol-text-series-sections">
      {series.parts.map(part => (
        <section class="ol-text-series-section">
          <div class="ol-text-series-section-head">
            <h2 class="ol-kr">{part.label}</h2>
            <span>{part.count} documents</span>
          </div>

          {part.groups.map(group => (
            <div class="ol-text-series-group">
              <h3 class="ol-kr">{group.label}</h3>
              <div class="ol-text-series-doc-list">
                {group.entries.map((entry, index) => (
                  <a class="ol-text-series-doc" href={url(getTextEntryUrl(entry))}>
                    <span class="ol-text-series-doc-num">
                      {String(entry.data.chapter ?? index + 1).padStart(2, '0')}
                    </span>
                    <span>
                      <strong class="ol-kr">{entry.data.title}</strong>
                      {entry.data.excerpt && <em class="ol-kr">{entry.data.excerpt}</em>}
                    </span>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </section>
      ))}
    </div>
  </article>
</TextLayout>

<script>
  import { initTagResultIndexes } from '../../../lib/client/content-filters';

  initTagResultIndexes();
</script>
