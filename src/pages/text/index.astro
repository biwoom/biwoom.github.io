---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import OLPrefixTagFilters from '../../components/common/OLPrefixTagFilters.astro';
import { url } from '../../lib/url';
import { buildTextHierarchy, formatTextTag } from '../../lib/text';
import { getPublicTags, groupTagsByPrefix } from '../../lib/tags';

const allText = await getCollection('text', e => e.data.published !== false);
const seriesList = buildTextHierarchy(allText);
const seriesCards = seriesList.map(series => {
  const firstEntry = series.entries[0];
  const summary = series.meta?.data.description ?? series.meta?.data.excerpt ?? firstEntry?.data.excerpt;
  const tags = getPublicTags(
    series.meta?.data.tags?.length
      ? series.meta.data.tags
      : [...new Set(series.entries.flatMap(entry => entry.data.tags))]
  );
  return { series, firstEntry, summary, tags };
});
const tagGroups = groupTagsByPrefix(seriesCards.flatMap(item => item.tags));
const PAGE_SIZE = 8;
---

<BaseLayout
  title="OL TEXT — 불교 문헌 콘텐츠"
  description="경전·논서·선어록·강의록을 번역하고 주석한 문헌 콘텐츠"
  pagefindBody={false}
>
  <main>
    <section class="ol-hero ol-grid-bg ol-grid-bg--text ol-hero--compact">
      <div class="ol-container">
        <span class="ol-section-label">TEXT · 문헌 콘텐츠</span>
        <h1 class="ol-kr">
          <em>날카롭고 통쾌한</em><br>
          불교문헌들.
        </h1>
        <p class="ol-lead ol-kr">
          OL TEXT는 경전·논서·선어록·강의록 등 불교문헌 중심의 콘텐츠입니다. 시리즈 단위로 읽고, 태그로 필요한 주제를 찾아볼 수 있습니다.
        </p>
      </div>
    </section>

    <hr class="ol-section-divider" />

    <section class="ol-section">
      <div class="ol-container">
        <div class="ol-text-index">
          <div class="ol-page-index-head">
            <span class="ol-section-label">TEXT · 불교 문헌</span>
            <h1 class="ol-kr ol-page-index-title">
              OL TEXT 시리즈
            </h1>

            <OLPrefixTagFilters
              id="text-prefix-filter"
              groups={tagGroups}
              targetSelector=".ol-text-series-card"
              totalCount={seriesCards.length}
              emptySelector="#text-no-results"
              pageSize={PAGE_SIZE}
              loadMoreWrapSelector="#text-loadmore-wrap"
              loadMoreButtonSelector="#text-loadmore-btn"
              loadMoreRemainingSelector="#text-loadmore-remaining"
            />
          </div>

          <section class="ol-text-series-grid" aria-label="TEXT 시리즈">
            {seriesCards.map(({ series, summary, tags }, index) => {
              return (
                <a class="ol-text-series-card" href={url(`/text/${series.slug}`)} data-tags={JSON.stringify(tags)} hidden={index >= PAGE_SIZE}>
                  <div>
                    <span class="ol-meta-label">{String(series.count).padStart(2, '0')} docs</span>
                    <h2 class="ol-kr">{series.label}</h2>
                    {summary && (
                      <p class="ol-kr">{summary}</p>
                    )}
                  </div>
                  {tags.length > 0 && (
                    <div class="ol-text-series-card-tags" aria-label={`${series.label} 태그`}>
                      {tags.slice(0, 6).map(tag => {
                        const parsed = formatTextTag(tag);
                        return (
                          <span class="ol-text-tag">
                            <span>{parsed.prefix}</span>
                            <strong>{parsed.label}</strong>
                          </span>
                        );
                      })}
                    </div>
                  )}
                </a>
              );
            })}
          </section>

          <p id="text-no-results" class="ol-kr ol-text-empty" hidden>
            선택한 태그에 해당하는 TEXT 시리즈가 없습니다.
          </p>

          {seriesList.length > PAGE_SIZE && (
            <div id="text-loadmore-wrap" class="ol-story-library-loadmore" hidden>
              <button id="text-loadmore-btn" class="ol-btn ol-btn-outline">
                더 보기
                <span id="text-loadmore-remaining">({seriesList.length - PAGE_SIZE})</span>
              </button>
            </div>
          )}

          {seriesList.length === 0 && (
            <p class="ol-kr ol-text-empty">아직 공개된 원고가 없습니다.</p>
          )}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
