---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { url } from '../../lib/url';

export async function getStaticPaths() {
  const posts = await getCollection('blog', e => e.data.published);
  return posts.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const pagefindBreadcrumb = ['BLOG', entry.data.category]
  .filter(Boolean)
  .join(' · ');
---

<BaseLayout
  title={`${entry.data.title} — OL BLOG`}
  description={entry.data.description}
  pagefindMeta={{
    title: entry.data.title,
    section: 'BLOG',
    sectionLabel: 'BLOG',
    category: entry.data.category,
    breadcrumb: pagefindBreadcrumb,
  }}
>
  <main>
    <section class="ol-section">
      <div class="ol-container ol-container--readable">
        <header class="ol-blog-detail-header">
          {entry.data.category && (
            <span class="ol-badge">{entry.data.category}</span>
          )}
          <h1 class="ol-kr ol-blog-detail-title">
            {entry.data.title}
          </h1>
          <div class="ol-blog-detail-meta">
            <span>{entry.data.date.toLocaleDateString('ko-KR')}</span>
            {entry.data.readingTime && <span>· {entry.data.readingTime}분 읽기</span>}
          </div>
        </header>
        <div class="ol-prose">
          <Content />
        </div>
        <footer class="ol-blog-detail-footer">
          <a href={url('/blog')} class="ol-blog-detail-back">← 목록으로</a>
        </footer>
      </div>
    </section>
  </main>
</BaseLayout>
