---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../lib/url';
---

<BaseLayout title="404 — 페이지를 찾을 수 없습니다" description="요청한 페이지가 존재하지 않습니다." pagefindBody={false}>
  <main>
    <section class="ol-not-found">
      <div>
        <div class="ol-not-found-code">404</div>
        <h1 class="ol-not-found-title ol-kr">
          길을 잃었습니다.
        </h1>
        <p class="ol-not-found-copy ol-kr">
          요청한 페이지가 존재하지 않거나 이동되었습니다.<br>
          아래 링크에서 다시 시작해 보세요.
        </p>
        <div class="ol-not-found-actions">
          <a href={url('/')} class="ol-btn ol-btn-primary ol-btn-sm">홈으로</a>
          <!-- <a href={url('/atlas')} class="ol-btn ol-btn-outline ol-btn-sm">ATLAS</a> -->
          <a href={url('/story')} class="ol-btn ol-btn-outline ol-btn-sm">STORY</a>
          <a href={url('/text')} class="ol-btn ol-btn-outline ol-btn-sm">TEXT</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
