---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import OLPrefixTagFilters from '../../components/common/OLPrefixTagFilters.astro';
import { url } from '../../lib/url';
import { buildStoryHierarchy, getStoryEntryUrl, formatStoryTag } from '../../lib/story';
import { groupTagsByPrefix } from '../../lib/tags';

const storyEntries = (
  await getCollection('story', e => e.data.published === true)
).sort((a, b) => (b.data.publishedAt?.valueOf() ?? 0) - (a.data.publishedAt?.valueOf() ?? 0));
const stories = buildStoryHierarchy(storyEntries);

const PAGE_SIZE = 8;

const storyCards = stories.map(story => {
  const entry = story.meta ?? story.entries[0];
  return {
    story,
    entry,
    tags: entry.data.tags,
  };
});
const tagGroups = groupTagsByPrefix(storyCards.flatMap(item => item.tags));

const statusLabel: Record<string, string> = {
  draft:     '초고',
  revising:  '수정중',
  ready:     '완료',
  published: '출판됨',
};

---

<BaseLayout
  title="OL STORY — 불교 콘텐츠 라이브러리"
  description="불교의 인물·설화·가르침 등 이야기 중심의 서사 콘텐츠입니다."
  pagefindBody={false}
>
  <main>
    <!-- Hero -->
    <section class="ol-hero">
      <div class="ol-container">
        <span class="ol-kicker">STORY · 이야기 콘텐츠</span>
        <h1 class="ol-kr">
          <em>이야기로 만나는</em><br>
          불교콘텐츠.
        </h1>
        <p class="ol-lead ol-kr">
          OL STORY는 불교의 인물·설화·가르침 등 이야기 중심의 서사 콘텐츠입니다. '이야기불교'는 논리적 문헌과는 또다른 종류의 감동을 전해줍니다.
        </p>
      </div>
    </section>
    
    <hr style="margin:80px 0 40px; width: 80%; margin:0 auto;" /> 

    <section class="ol-section">
      <div class="ol-container">
        <div style="margin-bottom: 48px;">
          <span class="ol-kicker">STORY · 불교 서사</span>
          <h1 style="font-size: 32px; margin-top: 10px; margin-bottom: 20px;" class="ol-kr">
            OL STORY 라이브러리
          </h1>
          <OLPrefixTagFilters
            id="story-prefix-filter"
            groups={tagGroups}
            targetSelector="#story-grid .ol-story-card"
            totalCount={storyCards.length}
            emptySelector="#story-no-results"
            pageSize={PAGE_SIZE}
            loadMoreWrapSelector="#story-loadmore-wrap"
            loadMoreButtonSelector="#story-loadmore-btn"
            loadMoreRemainingSelector="#story-loadmore-remaining"
          />

          <!-- <p style="color:var(--ol-muted);margin-top:12px;max-width:52ch;line-height:1.7;" class="ol-kr">
            완결된 불교 콘텐츠를 브라우저에서 읽거나 단일 HTML 파일로 내려받을 수 있습니다.
            모든 파일은 설치 없이 브라우저 하나로 열립니다.
          </p> -->
          <!-- <div style="margin-top:16px;">
            <a href={url('/text')} class="ol-btn ol-btn-outline ol-btn-sm">
              관련 TEXT 문서 보기 →
            </a>
          </div> -->
        </div>

        {stories.length > 0 ? (
          <div class="ol-grid-2" id="story-grid">
            {storyCards.map(({ story, entry, tags }, i) => (
              <a
                href={url(getStoryEntryUrl(entry))}
                class="ol-card ol-story-card"
                data-tags={JSON.stringify(tags)}
                data-index={i}
                style="display:flex;flex-direction:column;gap:20px;color:inherit;text-decoration:none;"
              >
                <div>
                  <span class="ol-mono-label" style="margin-bottom:8px;display:flex;align-items:center;gap:8px;">
                    <span>
                      {entry.data.publishedAt ? `${new Date(entry.data.publishedAt).getFullYear()} · ` : ''}
                      {entry.data.version}
                    </span>
                    <span class={`ol-text-status ol-text-status--${entry.data.status ?? 'draft'}`}>
                      {statusLabel[entry.data.status ?? 'draft']}
                    </span>
                    {entry.data.level && <span>· 난이도 {entry.data.level}/5</span>}
                  </span>
                  <h2 style="font-size:22px;margin:0 0 8px;" class="ol-kr">
                    {story.label}
                  </h2>
                  {entry.data.subtitle && (
                    <p style="font-size:14px;color:var(--ol-muted);margin:0 0 8px;" class="ol-kr">
                      {entry.data.subtitle}
                    </p>
                  )}
                  {entry.data.description && (
                    <p style="font-size:14px;color:var(--ol-muted);line-height:1.6;" class="ol-kr">
                      {entry.data.description}
                    </p>
                  )}
                </div>

                {tags.length > 0 && (
                  <div style="display:flex;gap:6px;flex-wrap:wrap;">
                    {tags.map(tag => {
                      const parsed = formatStoryTag(tag);
                      return <span class="ol-badge">{parsed.prefix} · {parsed.label}</span>;
                    })}
                  </div>
                )}

              </a>
            ))}
          </div>
        ) : (
          <div style="text-align:center;padding:80px 0;color:var(--ol-muted);">
            <p class="ol-kr" style="font-size:15px;">준비 중입니다.</p>
            <p class="ol-kr" style="font-size:13px;margin-top:8px;">
              <a href={url('/text')} style="color:inherit;">TEXT</a>에서 번역, 주석, 연구 노트를 먼저 만나보세요.
            </p>
          </div>
        )}

        <div id="story-no-results" style="display:none; text-align:center; padding:48px 0; color:var(--ol-muted); font-family:var(--ol-font-mono); font-size:13px;" class="ol-kr">
          선택한 태그에 해당하는 STORY가 없습니다.
        </div>

        {stories.length > PAGE_SIZE && (
          <div id="story-loadmore-wrap" style="display:flex; justify-content:center; margin-top:32px;">
            <button id="story-loadmore-btn" class="ol-btn ol-btn-outline">
              더 보기
              <span id="story-loadmore-remaining">({stories.length - PAGE_SIZE})</span>
            </button>
          </div>
        )}

      </div>
    </section>


    <!-- WHY callout -->
    <hr style="margin:80px 0 40px; width: 80%; margin:0 auto;" /> 
    <!-- <section class="ol-section">
      <div class="ol-container">
        <div class="ol-card" style="background: var(--ol-surface-2); border-color: var(--ol-border); padding: 36px;">
          <div class="ol-section-grid-2">
            <div>
              <span class="ol-kicker">WHY · ATLAS + STORY</span>
              <h3 style="font-size: 26px; margin-top: 12px; letter-spacing: -0.02em; line-height: 1.3;" class="ol-kr">"콘텐츠를 도구와 함께 배포한다는 것"</h3>
            </div>
            <p style="color: var(--ol-ink-2); line-height: 1.75; font-size: 14.5px;" class="ol-kr">
              기존 디지털 콘텐츠는 만든 사람의 플랫폼에 갇혀 있습니다.
              OL은 도구(ATLAS)와 콘텐츠(STORY)를 같은 파일로 묶어 배포합니다 — 책 한 권을 받는 것이, 그 책을 만든 작업실을 받는 일과 같아지도록.
            </p>
          </div>
        </div>
      </div>
    </section> -->
  </main>
</BaseLayout>
