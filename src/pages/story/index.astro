---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import OLPrefixTagFilters from '../../components/common/OLPrefixTagFilters.astro';
import { url } from '../../lib/url';
import { buildStoryHierarchy, getStoryEntryUrl, formatStoryTag } from '../../lib/story';
import { getPublicTags, groupTagsByPrefix } from '../../lib/tags';

const storyEntries = (
  await getCollection('story', e => e.data.published === true)
).sort((a, b) => (b.data.publishedAt?.valueOf() ?? 0) - (a.data.publishedAt?.valueOf() ?? 0));
const stories = buildStoryHierarchy(storyEntries);

const PAGE_SIZE = 8;

const storyCards = stories.map(story => {
  const entry = story.meta ?? story.entries[0];
  return {
    story,
    entry,
    tags: getPublicTags(entry.data.tags),
  };
});
const tagGroups = groupTagsByPrefix(storyCards.flatMap(item => item.tags));

const statusLabel: Record<string, string> = {
  draft:     '초고',
  revising:  '수정중',
  ready:     '완료',
  published: '출판됨',
};

---

<BaseLayout
  title="OL STORY — 불교 콘텐츠 라이브러리"
  description="불교의 인물·설화·가르침 등 이야기 중심의 서사 콘텐츠입니다."
  pagefindBody={false}
>
  <main>
    <!-- Hero -->
    <section class="ol-hero ol-grid-bg ol-grid-bg--story ol-hero--compact">
      <div class="ol-container">
        <span class="ol-section-label">STORY · 이야기 콘텐츠</span>
        <h1 class="ol-kr">
          <em>이야기로 만나는</em><br>
          불교콘텐츠.
        </h1>
        <p class="ol-lead ol-kr">
          OL STORY는 불교의 인물·설화·가르침 등 이야기 중심의 서사 콘텐츠입니다. '이야기불교'는 논리적 문헌과는 또다른 종류의 감동을 전해줍니다.
        </p>
      </div>
    </section>
    
    <hr class="ol-section-divider" />

    <section class="ol-section">
      <div class="ol-container">
        <div class="ol-page-index-head">
          <span class="ol-section-label">STORY · 불교 서사</span>
          <h1 class="ol-kr ol-page-index-title">
            OL STORY 라이브러리
          </h1>
          <OLPrefixTagFilters
            id="story-prefix-filter"
            groups={tagGroups}
            targetSelector="#story-grid .ol-story-card"
            totalCount={storyCards.length}
            emptySelector="#story-no-results"
            pageSize={PAGE_SIZE}
            loadMoreWrapSelector="#story-loadmore-wrap"
            loadMoreButtonSelector="#story-loadmore-btn"
            loadMoreRemainingSelector="#story-loadmore-remaining"
          />

        </div>

        {stories.length > 0 ? (
          <div class="ol-grid-2" id="story-grid">
            {storyCards.map(({ story, entry, tags }, i) => (
              <a
                href={url(getStoryEntryUrl(entry))}
                class="ol-card ol-story-card ol-story-library-card"
                data-tags={JSON.stringify(tags)}
                data-index={i}
              >
                <div>
                  <span class="ol-meta-label ol-story-library-meta">
                    <span>
                      {entry.data.publishedAt ? `${new Date(entry.data.publishedAt).getFullYear()} · ` : ''}
                      {entry.data.version}
                    </span>
                    <span class={`ol-text-status ol-text-status--${entry.data.status ?? 'draft'}`}>
                      {statusLabel[entry.data.status ?? 'draft']}
                    </span>
                    {entry.data.level && <span>· 난이도 {entry.data.level}/5</span>}
                  </span>
                  <h2 class="ol-kr ol-story-library-title">
                    {story.label}
                  </h2>
                  {entry.data.subtitle && (
                    <p class="ol-kr ol-story-library-subtitle">
                      {entry.data.subtitle}
                    </p>
                  )}
                  {entry.data.description && (
                    <p class="ol-kr ol-story-library-description">
                      {entry.data.description}
                    </p>
                  )}
                </div>

                {tags.length > 0 && (
                  <div class="ol-story-library-tags">
                    {tags.map(tag => {
                      const parsed = formatStoryTag(tag);
                      return <span class="ol-badge">{parsed.prefix} · {parsed.label}</span>;
                    })}
                  </div>
                )}

              </a>
            ))}
          </div>
        ) : (
          <div class="ol-story-library-empty">
            <p class="ol-kr ol-story-library-empty-title">준비 중입니다.</p>
            <p class="ol-kr ol-story-library-empty-copy">
              <a href={url('/text')}>TEXT</a>에서 번역, 주석, 연구 노트를 먼저 만나보세요.
            </p>
          </div>
        )}

        <div id="story-no-results" class="ol-kr ol-story-library-no-results" hidden>
          선택한 태그에 해당하는 STORY가 없습니다.
        </div>

        {stories.length > PAGE_SIZE && (
          <div id="story-loadmore-wrap" class="ol-story-library-loadmore" hidden>
            <button id="story-loadmore-btn" class="ol-btn ol-btn-outline">
              더 보기
              <span id="story-loadmore-remaining">({stories.length - PAGE_SIZE})</span>
            </button>
          </div>
        )}

      </div>
    </section>


    <!-- WHY callout -->
    <hr class="ol-section-divider" />
    <!-- <section class="ol-section">
      <div class="ol-container">
        <div class="ol-card ol-story-callout-card">
          <div class="ol-section-grid-2">
            <div>
              <span class="ol-section-label">WHY · ATLAS + STORY</span>
              <h3 class="ol-kr ol-story-callout-title">"콘텐츠를 도구와 함께 배포한다는 것"</h3>
            </div>
            <p class="ol-kr ol-story-callout-copy">
              기존 디지털 콘텐츠는 만든 사람의 플랫폼에 갇혀 있습니다.
              OL은 도구(ATLAS)와 콘텐츠(STORY)를 같은 파일로 묶어 배포합니다 — 책 한 권을 받는 것이, 그 책을 만든 작업실을 받는 일과 같아지도록.
            </p>
          </div>
        </div>
      </div>
    </section> -->
  </main>
</BaseLayout>
