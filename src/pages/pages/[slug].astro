---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { url } from '../../lib/url';

export async function getStaticPaths() {
  const pages = await getCollection('pages', e => e.data.published);
  return pages.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout
  title={`${entry.data.title} — OL`}
  description={entry.data.description}
>
  <main>
    <section class="ol-section">
      <div class="ol-container" style="max-width: 720px;">
        <header style="margin-bottom: 48px; padding-bottom: 24px; border-bottom: 1px solid var(--ol-border);">
          <h1 style="font-size: 36px; letter-spacing: -0.03em;" class="ol-kr">
            {entry.data.title}
          </h1>
          {entry.data.description && (
            <p style="margin-top: 12px; color: var(--ol-muted); font-size: 14px; line-height: 1.6;" class="ol-kr">
              {entry.data.description}
            </p>
          )}
        </header>
        <div class="ol-prose">
          <Content />
        </div>
        <footer style="margin-top: 64px; padding-top: 24px; border-top: 1px solid var(--ol-border);">
          <a href={url('/')} style="font-size: 12.5px; color: var(--ol-muted); text-decoration: none;">← 홈으로</a>
        </footer>
      </div>
    </section>
  </main>
</BaseLayout>
