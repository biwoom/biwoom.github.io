---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import OLEntityCard from '../../components/entity/OLEntityCard.astro';
import { getDesignAssetKeyUrl } from '../../lib/assets';
import { url } from '../../lib/url';
import { groupTagsByPrefix } from '../../lib/tags';

const entities = (await getCollection('entities', entry => entry.data.published))
  .sort((a, b) => a.data.name.ko.localeCompare(b.data.name.ko, 'ko'));

const TYPE_LABELS: Record<string, string> = {
  person: '인물',
  place: '장소',
  concept: '개념',
  text: '문헌',
  event: '사건',
  practice: '수행',
  school: '학파',
};

const coreTypes = ['person', 'place', 'concept'];
const visibleEntities = entities.filter(entity => coreTypes.includes(entity.data.type));
const typeCounts = coreTypes.map(type => ({
  type,
  label: TYPE_LABELS[type],
  count: visibleEntities.filter(entity => entity.data.type === type).length,
}));

const tagGroups = groupTagsByPrefix(visibleEntities.flatMap(entity => entity.data.tags ?? []));
const PAGE_SIZE = 12;
const initialQuery = Astro.url.searchParams.get('q') ?? '';
const dataList = (entity: { data: Record<string, any> }, key: string) =>
  Array.isArray(entity.data[key]) ? entity.data[key] : [];
const entityById = new Map(entities.map(entity => [entity.data.id, entity]));
const toNameCardReference = (id: string) => {
  const target = entityById.get(id);
  if (!target) return null;
  return {
    title: target.data.name.ko,
    path: url(`/entity/${target.data.type}s/${target.data.id}`),
  };
};
const relatedNameCards = (entity: { data: Record<string, any> }) => {
  const refs = [
    ...dataList(entity, 'primaryPlaces').map((item: any) => toNameCardReference(item.placeId)),
    ...dataList(entity, 'relatedPersons').map((item: any) => toNameCardReference(item.id)),
    ...dataList(entity, 'relatedConcepts').map((item: any) => toNameCardReference(item.id)),
    ...dataList(entity, 'relations').map((item: any) => {
      const targetId = item.subject === entity.data.id ? item.object : item.subject;
      return toNameCardReference(targetId);
    }),
  ].filter((item): item is { title: string; path: string } => Boolean(item?.title));
  const seen = new Set<string>();
  return refs.filter(item => {
    const key = `${item.title}|${item.path}`;
    if (seen.has(key)) return false;
    seen.add(key);
    return true;
  }).slice(0, 6);
};
---

<BaseLayout
  title="OL NET Explore — 이름 탐색"
  description="OL 이름카드를 검색하고 필터링하기 위한 NET 탐색 전용 페이지입니다."
  pagefindBody={false}
>
  <main class="net-explore-page" data-net-explore>
    <section class="net-explore-head">
      <div class="net-explore-container">
        <div class="net-breadcrumb">
          <a href={url('/net')}>NET</a>
          <span>/</span>
          <strong>EXPLORE</strong>
        </div>
        <div class="net-explore-title">
          <div>
            <span class="ol-section-label">NET EXPLORER · 검색결과 전용 화면</span>
            <h1 class="ol-kr">이름을 찾고 관계를 확인합니다.</h1>
          </div>
          <form class="net-explore-search" action={url('/net/explore')} method="get" role="search" aria-label="NET 이름카드 검색">
            <input name="q" type="search" placeholder="이름카드 검색" autocomplete="off" value={initialQuery} data-net-query />
            <button type="submit" class="net-search-submit" aria-label="검색">
              <svg aria-hidden="true" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8" />
                <line x1="21" y1="21" x2="16.65" y2="16.65" />
              </svg>
              <span>검색</span>
            </button>
            <button type="button" class="net-search-clear" data-net-search-clear hidden>검색어 초기화</button>
          </form>
        </div>
      </div>
    </section>

    <section class="net-explorer-section">
      <div class="net-explore-container">
        <div class="net-explorer-shell">
          <aside class="net-filter-panel" aria-label="NET 필터">
            <details class="net-filter-disclosure" open data-net-filter-disclosure>
              <summary>
                <span>필터</span>
                <em data-net-filter-count hidden>0</em>
              </summary>
              <div class="net-filter-content">
                <div class="net-panel-block">
                  <span class="ol-meta-label">TYPE FILTER</span>
                  <div class="net-filter-list" data-net-type-filter>
                    <button type="button" class="net-filter-option active" data-net-type="all">전체 <span>{visibleEntities.length}</span></button>
                    {typeCounts.map(item => (
                      <button type="button" class="net-filter-option" data-net-type={item.type}>
                        {item.label} <span>{item.count}</span>
                      </button>
                    ))}
                  </div>
                </div>

                <div class="net-panel-block">
                  <span class="ol-meta-label">PREFIX TAGS</span>
                  {tagGroups.length > 0 ? (
                    <div class="net-prefix-filter" data-net-tag-filter>
                      {tagGroups.map(group => (
                        <details class="net-prefix-group" data-prefix={group.prefix}>
                          <summary>
                            <span>{group.prefix}</span>
                            <em>{group.tags.length}</em>
                          </summary>
                          <div class="net-prefix-options">
                            {group.tags.map(item => (
                              <button type="button" data-net-tag={item.tag} data-net-prefix={group.prefix}>
                                <span>{item.label}</span>
                                <em>{item.count}</em>
                              </button>
                            ))}
                          </div>
                        </details>
                      ))}
                    </div>
                  ) : (
                    <p class="net-panel-note ol-kr">태그 필터는 다음 단계에서 연결합니다.</p>
                  )}
                </div>

                <p class="net-panel-note ol-kr">
                  같은 prefix 안에서는 OR, 서로 다른 prefix 사이는 AND 조건으로 필터링합니다.
                </p>
                <button type="button" class="net-reset-button net-reset-button--sidebar" data-net-reset>
                  필터 초기화
                </button>
              </div>
            </details>
          </aside>

          <div class="net-list-panel">
            <div class="net-list-toolbar">
              <div>
                <span class="ol-meta-label">RESULT LIST</span>
                <strong class="ol-kr"><span data-net-result-count>{visibleEntities.length}</span>개 항목</strong>
              </div>
              <button type="button" class="net-reset-button net-reset-button--primary" data-net-reset>필터 초기화</button>
            </div>

            {visibleEntities.length > 0 ? (
              <div class="net-entity-grid">
                {visibleEntities.map(entity => (
                  <div
                    class="net-entity-item"
                    data-net-entity
                    data-id={entity.data.id}
                    data-type={entity.data.type}
                    data-tags={JSON.stringify(entity.data.tags ?? [])}
                    data-detail={JSON.stringify({
                      type: TYPE_LABELS[entity.data.type] ?? entity.data.type,
                      name: entity.data.name.ko,
                      names: [
                        entity.data.name.en,
                        entity.data.name.sanskrit,
                        entity.data.name.pali,
                        entity.data.name.chinese,
                      ].filter(Boolean),
                      aliases: entity.data.aliases ?? [],
                      profileImage: entity.data.design?.imageAsset
                        ? getDesignAssetKeyUrl(entity.data.design.imageAsset)
                        : entity.data.design?.profileImage
                          ? url(entity.data.design.profileImage)
                          : '',
                      description: entity.data.description ?? '',
                      tags: entity.data.tags ?? [],
                      relatedStories: [
                        ...dataList(entity, 'appearsIn').filter((item: any) => item.type === 'story'),
                        ...dataList(entity, 'relatedStories'),
                      ].slice(0, 4),
                      relatedText: dataList(entity, 'relatedText').slice(0, 4),
                      relatedDesign: dataList(entity, 'relatedDesign').slice(0, 4),
                      relatedNameCards: relatedNameCards(entity),
                      relationCount: dataList(entity, 'relations').length
                        + dataList(entity, 'primaryPlaces').length
                        + dataList(entity, 'relatedPersons').length
                        + dataList(entity, 'relatedConcepts').length,
                      sourceCount: entity.data.sources?.length ?? 0,
                      href: url(`/entity/${entity.data.type}s/${entity.data.id}`),
                    })}
                    data-search-text={[
                      entity.data.name.ko,
                      entity.data.name.en,
                      entity.data.name.sanskrit,
                      entity.data.name.pali,
                      entity.data.name.chinese,
                      entity.data.description,
                      ...(entity.data.aliases ?? []),
                      ...(entity.data.tags ?? []),
                    ].filter(Boolean).join(' ')}
                  >
                    <OLEntityCard entity={entity.data} />
                  </div>
                ))}
              </div>
            ) : (
              <p class="ol-kr net-empty">아직 공개된 이름카드가 없습니다.</p>
            )}
            <p class="ol-kr net-empty" data-net-empty hidden>조건에 맞는 이름카드가 없습니다.</p>
            {visibleEntities.length > PAGE_SIZE && (
              <div class="net-loadmore-wrap" data-net-loadmore-wrap>
                <button type="button" class="ol-btn ol-btn-outline" data-net-loadmore>
                  더 보기
                  <span data-net-loadmore-remaining>({visibleEntities.length - PAGE_SIZE})</span>
                </button>
              </div>
            )}
          </div>

          <div class="net-detail-backdrop" data-net-detail-close hidden></div>
          <aside class="net-detail-panel" aria-label="이름카드 상세 패널 예정 영역">

            <figure class="net-detail-profile" data-net-detail-profile hidden>
              <img src="" alt="" loading="lazy" decoding="async" data-net-detail-profile-image />
            </figure>
            <span class="ol-meta-label" data-net-detail-type>NAME CARD DETAIL</span>
            <h2 class="ol-kr" data-net-detail-name>선택한 이름카드의 맥락</h2>
            <p class="net-detail-names" data-net-detail-names hidden></p>
            <p class="ol-kr" data-net-detail-description>
              선택한 이름카드의 상세 내용이 표시될 영역입니다. 하단에는 관련 STORY, TEXT,
              DESIGN 정보가 이어지고, 이후 관계망 그래프가 이 패널의 중심 시각화가 됩니다.
            </p>
            <div class="net-detail-tags" data-net-detail-tags hidden></div>
            <div class="net-detail-context" data-net-detail-context hidden></div>
            <div class="net-detail-placeholder" data-net-detail-placeholder>
              <span>이름카드를 선택하면 요약 정보가 표시됩니다.</span>
              <span>상세 문서는 선택 후 링크로 이동합니다.</span>
              <span>관계망 그래프</span>
              <span>장소 이름카드 지도 탭</span>
            </div>
            <a class="net-detail-link" href="#" data-net-detail-link hidden>상세 문서 열기</a>
            <button type="button" class="net-detail-close" data-net-detail-close aria-label="상세 패널 닫기">닫기</button>
          </aside>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  function setupNetExploreFilters() {
    const root = document.querySelector<HTMLElement>('[data-net-explore]');
    const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-net-entity]'));
    const typeButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-net-type]'));
    const tagButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-net-tag]'));
    const resultCount = document.querySelector<HTMLElement>('[data-net-result-count]');
    const empty = document.querySelector<HTMLElement>('[data-net-empty]');
    const resetButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-net-reset]'));
    const loadmoreWrap = document.querySelector<HTMLElement>('[data-net-loadmore-wrap]');
    const loadmoreButton = document.querySelector<HTMLButtonElement>('[data-net-loadmore]');
    const loadmoreRemaining = document.querySelector<HTMLElement>('[data-net-loadmore-remaining]');
    const searchForm = document.querySelector<HTMLFormElement>('.net-explore-search');
    const searchInput = document.querySelector<HTMLInputElement>('[data-net-query]');
    const searchClear = document.querySelector<HTMLButtonElement>('[data-net-search-clear]');
    const filterDisclosure = document.querySelector<HTMLDetailsElement>('[data-net-filter-disclosure]');
    const filterCount = document.querySelector<HTMLElement>('[data-net-filter-count]');
    const detailPanel = document.querySelector<HTMLElement>('.net-detail-panel');
    const detailBackdrop = document.querySelector<HTMLElement>('.net-detail-backdrop');
    const detailCloseButtons = Array.from(document.querySelectorAll<HTMLElement>('[data-net-detail-close]'));
    if (!cards.length || !typeButtons.length || root?.dataset.ready === 'true') return;
    if (root) root.dataset.ready = 'true';

    const PAGE_SIZE = 12;
    const mobileQuery = window.matchMedia('(max-width: 640px)');
    const selectedTags = new Map<string, Set<string>>();
    let selectedType = 'all';
    let selectedQuery = '';
    let focusId = '';
    let visibleCount = PAGE_SIZE;
    const normalize = (value: string) => value.trim().toLocaleLowerCase('ko-KR');
    const detailType = document.querySelector<HTMLElement>('[data-net-detail-type]');
    const detailName = document.querySelector<HTMLElement>('[data-net-detail-name]');
    const detailNames = document.querySelector<HTMLElement>('[data-net-detail-names]');
    const detailProfile = document.querySelector<HTMLElement>('[data-net-detail-profile]');
    const detailProfileImage = document.querySelector<HTMLImageElement>('[data-net-detail-profile-image]');
    const detailDescription = document.querySelector<HTMLElement>('[data-net-detail-description]');
    const detailTags = document.querySelector<HTMLElement>('[data-net-detail-tags]');
    const detailContext = document.querySelector<HTMLElement>('[data-net-detail-context]');
    const detailPlaceholder = document.querySelector<HTMLElement>('[data-net-detail-placeholder]');
    const detailLink = document.querySelector<HTMLAnchorElement>('[data-net-detail-link]');

    type DetailReference = {
      title: string;
      path: string;
      role?: string;
    };

    type DetailData = {
      type: string;
      name: string;
      names: string[];
      aliases: string[];
      profileImage?: string;
      description: string;
      tags: string[];
      relatedStories: DetailReference[];
      relatedText: DetailReference[];
      relatedDesign: DetailReference[];
      relatedNameCards: DetailReference[];
      relationCount: number;
      sourceCount: number;
      href: string;
    };

    const readCardTags = (card: HTMLElement) => {
      try {
        return JSON.parse(card.dataset.tags || '[]') as string[];
      } catch {
        return [];
      }
    };

    const readCardDetail = (card: HTMLElement) => {
      try {
        return JSON.parse(card.dataset.detail || '{}') as DetailData;
      } catch {
        return null;
      }
    };

    const appendReferenceSection = (
      container: HTMLElement,
      title: string,
      refs: DetailReference[],
      { showRole = false, plainLinks = false } = {},
    ) => {
      if (!refs.length) return;
      const section = document.createElement('section');
      section.className = 'net-detail-context-section';
      if (plainLinks) section.dataset.linkPlain = 'true';
      const heading = document.createElement('h3');
      heading.textContent = title;
      const list = document.createElement('ul');
      refs.forEach(ref => {
        const item = document.createElement('li');
        const label = showRole && ref.role ? `${ref.title} · ${ref.role}` : ref.title;
        if (ref.path) {
          const link = document.createElement('a');
          link.href = ref.path;
          link.textContent = label;
          item.append(link);
        } else {
          const text = document.createElement('span');
          text.textContent = label;
          item.append(text);
        }
        list.append(item);
      });
      section.append(heading, list);
      container.append(section);
    };

    const closeDetailModal = () => {
      detailPanel?.classList.remove('mobile-open');
      if (detailBackdrop) detailBackdrop.hidden = true;
      document.documentElement.classList.remove('net-detail-modal-lock');
    };

    const openDetailModal = () => {
      if (!mobileQuery.matches) return;
      detailPanel?.classList.add('mobile-open');
      if (detailBackdrop) detailBackdrop.hidden = false;
      document.documentElement.classList.add('net-detail-modal-lock');
    };

    const selectCard = (card: HTMLElement) => {
      const detail = readCardDetail(card);
      if (!detail) return;
      cards.forEach(item => item.classList.toggle('active', item === card));
      if (detailType) detailType.textContent = detail.type;
      if (detailName) detailName.textContent = detail.name;
      if (detailNames) {
        const names = [...detail.names, ...detail.aliases];
        detailNames.textContent = names.join(' · ');
        detailNames.hidden = names.length === 0;
      }
      if (detailProfile && detailProfileImage) {
        const profileImage = detail.profileImage?.trim();
        if (profileImage) {
          detailProfileImage.src = profileImage;
          detailProfileImage.alt = `${detail.name} 프로필 이미지`;
          detailProfile.hidden = false;
        } else {
          detailProfileImage.removeAttribute('src');
          detailProfileImage.alt = '';
          detailProfile.hidden = true;
        }
      }
      if (detailDescription) {
        detailDescription.textContent = detail.description || '아직 요약 설명이 준비되지 않았습니다.';
      }
      if (detailTags) {
        detailTags.innerHTML = '';
        detail.tags.forEach(tag => {
          const chip = document.createElement('span');
          chip.className = 'ol-meta-badge';
          chip.textContent = tag;
          detailTags.append(chip);
        });
        detailTags.hidden = detail.tags.length === 0;
      }
      if (detailContext) {
        detailContext.innerHTML = '';
        const stats = document.createElement('div');
        stats.className = 'net-detail-stats';
        [
          ['관련 문서', detail.relatedStories.length + detail.relatedText.length + detail.relatedDesign.length],
          ['관련 이름', detail.relatedNameCards.length],
          ['태그', detail.tags.length],
          ['출처', detail.sourceCount],
        ].forEach(([label, value]) => {
          const stat = document.createElement('div');
          stat.className = 'net-detail-stat';
          const number = document.createElement('strong');
          number.textContent = String(value);
          const caption = document.createElement('span');
          caption.textContent = String(label);
          stat.append(number, caption);
          stats.append(stat);
        });
        detailContext.append(stats);
        appendReferenceSection(detailContext, '관련 STORY', detail.relatedStories);
        appendReferenceSection(detailContext, '관련 TEXT', detail.relatedText);
        appendReferenceSection(detailContext, '관련 DESIGN', detail.relatedDesign);
        appendReferenceSection(detailContext, '관련 이름카드', detail.relatedNameCards, {
          showRole: false,
          plainLinks: true,
        });
        detailContext.hidden = false;
      }
      if (detailPlaceholder) detailPlaceholder.hidden = true;
      if (detailLink) {
        detailLink.href = detail.href;
        detailLink.hidden = false;
      }
      openDetailModal();
    };

    const syncFromUrl = () => {
      const params = new URLSearchParams(window.location.search);
      const type = params.get('type');
      focusId = params.get('focus') ?? '';
      selectedQuery = normalize(params.get('q') ?? '');
      if (searchInput) searchInput.value = params.get('q') ?? '';
      selectedType = type && typeButtons.some(button => button.dataset.netType === type) ? type : 'all';
      selectedTags.clear();
      params.getAll('tag').forEach(tag => {
        const button = tagButtons.find(item => item.dataset.netTag === tag);
        const prefix = button?.dataset.netPrefix;
        if (!prefix) return;
        const group = selectedTags.get(prefix) ?? new Set<string>();
        group.add(tag);
        selectedTags.set(prefix, group);
      });
    };

    const writeUrl = () => {
      const params = new URLSearchParams();
      if (selectedQuery) params.set('q', selectedQuery);
      if (selectedType !== 'all') params.set('type', selectedType);
      if (focusId) params.set('focus', focusId);
      selectedTags.forEach(tags => {
        tags.forEach(tag => params.append('tag', tag));
      });
      const query = params.toString();
      window.history.replaceState(null, '', `${window.location.pathname}${query ? `?${query}` : ''}`);
    };

    const cardMatches = (card: HTMLElement) => {
      if (selectedQuery && !normalize(card.dataset.searchText || '').includes(selectedQuery)) return false;
      if (selectedType !== 'all' && card.dataset.type !== selectedType) return false;
      const tags = readCardTags(card);
      return Array.from(selectedTags.values()).every(group =>
        Array.from(group).some(tag => tags.includes(tag)),
      );
    };

    const syncControls = () => {
      typeButtons.forEach(button => {
        button.classList.toggle('active', button.dataset.netType === selectedType);
      });
      tagButtons.forEach(button => {
        const prefix = button.dataset.netPrefix;
        const tag = button.dataset.netTag;
        button.classList.toggle('active', Boolean(prefix && tag && selectedTags.get(prefix)?.has(tag)));
      });
      document.querySelectorAll<HTMLElement>('.net-prefix-group').forEach(group => {
        const prefix = group.dataset.prefix;
        group.classList.toggle('active', Boolean(prefix && selectedTags.get(prefix)?.size));
      });
      if (searchClear) searchClear.hidden = !selectedQuery;
      if (filterCount) {
        const selectedFilterCount = (selectedType !== 'all' ? 1 : 0)
          + Array.from(selectedTags.values()).reduce((total, group) => total + group.size, 0);
        filterCount.textContent = String(selectedFilterCount);
        filterCount.hidden = selectedFilterCount === 0;
      }
    };

    const apply = ({ updateUrl = true, resetPage = false } = {}) => {
      if (resetPage) visibleCount = PAGE_SIZE;
      const matchedCards = cards.filter(cardMatches);
      cards.forEach(card => {
        card.hidden = true;
      });
      matchedCards.forEach((card, index) => {
        card.hidden = index >= visibleCount;
      });
      if (resultCount) resultCount.textContent = String(matchedCards.length);
      if (empty) empty.hidden = matchedCards.length > 0;
      if (loadmoreWrap && loadmoreRemaining) {
        const remaining = matchedCards.length - visibleCount;
        loadmoreWrap.hidden = remaining <= 0;
        loadmoreRemaining.textContent = `(${remaining})`;
      }
      syncControls();
      if (focusId) {
        const focusedCard = matchedCards.find(card => !card.hidden && card.dataset.id === focusId);
        if (focusedCard) {
          selectCard(focusedCard);
          focusId = '';
          if (updateUrl) writeUrl();
        }
      }
      if (updateUrl) writeUrl();
    };

    typeButtons.forEach(button => {
      button.addEventListener('click', () => {
      selectedType = button.dataset.netType || 'all';
      focusId = '';
      apply({ resetPage: true });
    });
    });

    cards.forEach(card => {
      const link = card.querySelector<HTMLAnchorElement>('a');
      link?.addEventListener('click', event => {
        if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || event.button !== 0) return;
        event.preventDefault();
        selectCard(card);
      });
    });

    tagButtons.forEach(button => {
      button.addEventListener('click', () => {
        const prefix = button.dataset.netPrefix;
        const tag = button.dataset.netTag;
        if (!prefix || !tag) return;
        const group = selectedTags.get(prefix) ?? new Set<string>();
        if (group.has(tag)) {
          group.delete(tag);
        } else {
          group.add(tag);
        }
        if (group.size > 0) {
          selectedTags.set(prefix, group);
        } else {
          selectedTags.delete(prefix);
        }
        focusId = '';
        apply({ resetPage: true });
      });
    });

    const resetFilters = () => {
      selectedType = 'all';
      selectedQuery = '';
      focusId = '';
      if (searchInput) searchInput.value = '';
      selectedTags.clear();
      apply({ resetPage: true });
    };

    resetButtons.forEach(button => {
      button.addEventListener('click', resetFilters);
    });

    loadmoreButton?.addEventListener('click', () => {
      visibleCount += PAGE_SIZE;
      apply({ updateUrl: false });
    });

    searchForm?.addEventListener('submit', event => {
      event.preventDefault();
      selectedQuery = normalize(searchInput?.value ?? '');
      focusId = '';
      apply({ resetPage: true });
    });

    searchClear?.addEventListener('click', () => {
      selectedQuery = '';
      if (searchInput) {
        searchInput.value = '';
        searchInput.focus();
      }
      focusId = '';
      apply({ resetPage: true });
    });

    detailCloseButtons.forEach(button => {
      button.addEventListener('click', closeDetailModal);
    });

    document.addEventListener('keydown', event => {
      if (event.key === 'Escape') closeDetailModal();
    });

    mobileQuery.addEventListener('change', event => {
      if (event.matches && filterDisclosure) {
        filterDisclosure.open = false;
      }
      if (!event.matches) closeDetailModal();
    });

    if (mobileQuery.matches && filterDisclosure) {
      filterDisclosure.open = false;
    }

    syncFromUrl();
    apply({ updateUrl: false, resetPage: true });
  }

  document.addEventListener('DOMContentLoaded', setupNetExploreFilters);
</script>
