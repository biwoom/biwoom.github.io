---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import OLEntityCard from '../../components/entity/OLEntityCard.astro';
import { url } from '../../lib/url';

const entities = (await getCollection('entities', entry => entry.data.published))
  .sort((a, b) => a.data.name.ko.localeCompare(b.data.name.ko, 'ko'));

const TYPE_LABELS: Record<string, string> = {
  person: '인물',
  place: '장소',
  concept: '개념',
};

const coreTypes = ['person', 'place', 'concept'];
const typeCounts = coreTypes.map(type => ({
  type,
  label: TYPE_LABELS[type],
  count: entities.filter(entity => entity.data.type === type).length,
}));

const featuredEntities = [
  ...coreTypes.flatMap(type => entities.filter(entity => entity.data.type === type).slice(0, 4)),
].slice(0, 12);
const netExploreHref = (entity: { data: { id: string; type: string; name: { ko: string } } }) =>
  url(`/net/explore?type=${entity.data.type}&q=${encodeURIComponent(entity.data.name.ko)}&focus=${entity.data.id}`);
---

<BaseLayout
  title="OL NET — 불교 지식 연결망"
  description="인물, 장소, 개념의 이름을 중심으로 OL의 STORY, TEXT, DESIGN을 연결하는 탐색 메뉴입니다."
  pagefindBody={false}
>
  <main>
    <section class="ol-hero net-hero ol-grid-bg ol-grid-bg--net">
      <div class="ol-container net-hero-inner">
        <span class="ol-section-label">NET · 지식 연결망</span>
        <h1 class="ol-kr">
          <em>이름 하나를</em> 따라<br />
          지혜의 올이 이어집니다.
        </h1>
        <p class="ol-lead ol-kr">
          OL NET은 인물, 장소, 개념의 이름을 따라 불교 콘텐츠의 흐름을 살펴보는 탐색 공간입니다. 하나의 이름에서 다른 이름으로, 다시 이야기와 문헌으로 이어지는 길이 이어집니다.
        </p>

        <a href={url('/net/explore')} class="net-hero-cta">
          <span>이름카드 탐색하기</span>
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>

        <form class="net-hero-search" action={url('/net/explore')} method="get" role="search" aria-label="이름카드 검색">
          <label class="net-search-label" for="net-q">이름카드 검색</label>
          <div class="net-search-box">
            <svg aria-hidden="true" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8" />
              <line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
            <input
              id="net-q"
              name="q"
              type="search"
              placeholder="예: 붓다, 사위성, 연기, 공"
              autocomplete="off"
            />
            <button type="submit">검색</button>
          </div>
        </form>
      </div>
    </section>

    <section class="ol-section net-featured-section">
      <div class="ol-container">
        <div class="net-type-strip net-type-strip--section" aria-label="이름카드 유형">
          <a href={url('/net/explore')} class="net-type-chip active">
            전체 <span>{entities.length}</span>
          </a>
          {typeCounts.map(item => (
            <a href={url(`/net/explore?type=${item.type}`)} class="net-type-chip">
              {item.label} <span>{item.count}</span>
            </a>
          ))}
        </div>

        <div class="net-section-head">
          <div>
            <span class="ol-section-label">이름카드 · 최근 기준점</span>
            <h2 class="ol-kr">NET으로 들어가는 첫 항목</h2>
          </div>
          <a href={url('/net/explore')} class="net-explore-cta">
            <span>탐색 페이지 열기</span>
            <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14" />
              <path d="m12 5 7 7-7 7" />
            </svg>
          </a>
        </div>

        {featuredEntities.length > 0 ? (
          <div class="net-entity-grid">
            {featuredEntities.map(entity => (
              <OLEntityCard entity={entity.data} href={netExploreHref(entity)} compact />
            ))}
          </div>
        ) : (
          <p class="ol-kr net-empty">아직 공개된 이름카드가 없습니다.</p>
        )}
      </div>
    </section>
  </main>
</BaseLayout>
